# Copy to `.env` in the repo root. Docker Compose reads it for `${VAR}` substitution in `compose.yml`.
# Services `kg-ingestor` and `matrix-bot` also receive this file as `env_file` (app config).

# --- Matrix (external Synapse / homeserver) ---
MATRIX_API_URL=https://example.org/
MATRIX_USER=bot
MATRIX_PASSWORD=change-me
MATRIX_DEBUG=false

# --- Ollama (host; not in this compose file) ---
# Для доступа из контейнеров по bridge: запустите Ollama с OLLAMA_HOST=0.0.0.0:11434
OLLAMA_URL=http://127.0.0.1:11434
GEN_MODEL=cajina/gemma4_e2b-q4_k_s:v01
# Эмбеддинги по умолчанию: embeddinggemma (~621MB, 768 измерений; альтернатива — nomic-embed-text). Смена модели — полный ingest.
EMBED_MODEL=embeddinggemma

# --- Neo4j / Qdrant (пароль и коллекция; URI ниже переопределяются для compose-сервисов) ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=edelweiss
# Локальный `go run` / отладка на хосте:
NEO4J_URI=bolt://127.0.0.1:7687
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=edelweiss

# --- Bot ---
BOT_COMMAND_PREFIX=!edel
MATRIX_BOT_DB=/data/matrix-bot.db
HTTP_TIMEOUT=120s

# --- Assistant (Inworld STT + Cartesia TTS) ---
INWORLD_API_KEY=
INWORLD_STT_MODEL=base
CARTESIA_API_KEY=
CARTESIA_MODEL_ID=sonic-3.5
# Russian voices example (Cartesia /voices?language=ru):
# Sergei=1e4176b1-3db9-44d6-a601-4fe68b041942
# Tatiana=064b17af-d36b-4bfb-b003-be07dba1b649
CARTESIA_VOICE_ID=1e4176b1-3db9-44d6-a601-4fe68b041942
ASSISTANT_AUDIO_SAMPLE_RATE=16000
ASSISTANT_CHUNK_MS=100
ASSISTANT_TTS_DIR=var/tss
ASSISTANT_AUDIO_REC_DIR=var/audio-rec
ASSISTANT_STT_DIR=var/stt
ASSISTANT_PERF_LOG=var/logs/performance.jsonl

# --- Docker Compose: kg-ingestor (сеть bridge, имена сервисов neo4j / qdrant) ---
COMPOSE_INGEST_DOCS_ROOT=/repo/docs/project
COMPOSE_INGEST_NEO4J_URI=bolt://neo4j:7687
COMPOSE_INGEST_QDRANT_URL=http://qdrant:6333
# Ollama на хосте: host.docker.internal (нужен extra_hosts в compose; на Linux часто работает host-gateway)
COMPOSE_INGEST_OLLAMA_URL=http://host.docker.internal:11434

# --- Docker Compose: matrix-bot (по умолчанию host network → localhost и опубликованные порты) ---
COMPOSE_BOT_NETWORK_MODE=host
COMPOSE_BOT_NEO4J_URI=bolt://127.0.0.1:7687
COMPOSE_BOT_QDRANT_URL=http://127.0.0.1:6333
# Ollama для контейнера matrix-bot (по умолчанию localhost; не смешивается с OLLAMA_URL для go run)
COMPOSE_BOT_OLLAMA_URL=http://127.0.0.1:11434

# --- Порты (опционально) ---
DOCS_PORT=5496
NEO4J_HTTP_PORT=7474
NEO4J_BOLT_PORT=7687
QDRANT_HTTP_PORT=6333

# --- Elasticsearch + Kibana + Filebeat (profile elastic; см. deploy/elastic/README.md) ---
ELASTICSEARCH_PORT=9200
KIBANA_PORT=5601
ELASTIC_VERSION=8.15.3
KIBANA_VERSION=8.15.3
FILEBEAT_VERSION=8.15.3
ES_NODE_NAME=es01
ES_CLUSTER_NAME=edelweiss-logs
KIBANA_ELASTICSEARCH_HOSTS=http://elasticsearch:9200

# --- Ingestor вне Docker: из каталога services/ ---
# DOCS_ROOT=../docs/project
