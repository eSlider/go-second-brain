# Copy to .env and adjust. Existing keys from your environment (Matrix, Ollama) stay as-is.

# --- Matrix (external Synapse / homeserver) ---
MATRIX_API_URL=https://example.org/
MATRIX_USER=bot
MATRIX_PASSWORD=change-me
MATRIX_DEBUG=false

# --- Ollama on host (not in Docker). Listen on 0.0.0.0:11434 for containers. ---
OLLAMA_URL=http://127.0.0.1:11434
GEN_MODEL=gemma3:1b
EMBED_MODEL=nomic-embed-text

# --- Neo4j (compose service neo4j) ---
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=edelweiss

# --- Qdrant (compose service qdrant) ---
QDRANT_URL=http://qdrant:6333
QDRANT_COLLECTION=edelweiss

# --- Bot ---
BOT_COMMAND_PREFIX=!edel
MATRIX_BOT_DB=/data/matrix-bot.db

# --- Ingestor ---
# Из каталога services/: DOCS_ROOT=../docs/project
# В Docker compose задаётся /repo/docs/project
# DOCS_ROOT=../docs/project
