# Secrets and local overrides. Copy to `.env` in the repo root.
# Non-secret defaults live in config.yaml.example → config.yaml.

# --- Matrix (external Synapse / homeserver) ---
MATRIX_API_URL=https://example.org/
MATRIX_USER=bot
MATRIX_PASSWORD=change-me
MATRIX_DEBUG=false

# --- Neo4j / Qdrant ---
NEO4J_USER=neo4j
NEO4J_PASSWORD=change-me
NEO4J_URI=bolt://127.0.0.1:7687
QDRANT_URL=http://127.0.0.1:6333
QDRANT_COLLECTION=knowledge

# --- Ollama (host; not in compose by default) ---
OLLAMA_URL=http://127.0.0.1:11434

# --- Bot ---
BOT_COMMAND_PREFIX=!brain
MATRIX_BOT_DB=/data/matrix-bot.db

# --- Assistant (Inworld STT + Cartesia TTS) ---
INWORLD_API_KEY=
CARTESIA_API_KEY=
CARTESIA_VOICE_ID=

# --- Optional: override config file path ---
# CONFIG_PATH=/path/to/config.yaml
